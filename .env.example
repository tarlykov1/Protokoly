APP_ENV=demo
DEMO_MODE=true
DEMO_BASIC_AUTH_ENABLED=true
DATABASE_URL=postgresql+psycopg://protocols:change-me@db:5432/protocols
POSTGRES_DB=protocols
POSTGRES_USER=protocols
POSTGRES_PASSWORD=change-me
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20
IMPORT_SESSION_TTL_HOURS=24
WEB_CONCURRENCY=2
APP_HOST=0.0.0.0
APP_PORT=8000
PUBLIC_BASE_URL=https://demo.example.ru
ALLOWED_HOSTS=demo.example.ru,localhost,127.0.0.1
FORWARDED_ALLOW_IPS=172.16.0.0/12,127.0.0.1
LOG_LEVEL=INFO
APP_VERSION=0.5.0-demo
GIT_COMMIT=local
BUILD_DATE=local
BACKUP_RETENTION_DAYS=14
